# =====Aggregation Engine Configuration=====
# Error count thresholds before incident creation
AGGREGATION_THRESHOLD_LOW=5           # 5 same errors → low severity
AGGREGATION_THRESHOLD_MEDIUM=10       # 10 same errors → medium severity
AGGREGATION_THRESHOLD_HIGH=20         # 20 same errors → high severity
AGGREGATION_THRESHOLD_CRITICAL=50     # 50+ same errors → critical severity
AGGREGATION_WINDOW_SECONDS=3600       # 1 hour - how long to track error groups
